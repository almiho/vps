# OpenClaw agent workspace - has its own git repo managed by OpenClaw
agents/infrastructure/

# Secrets and credentials - never commit
.env
*.env
config/secrets.*
**/.secrets

# SQLite databases (contain personal data - back up separately)
data/*.db
data/*.db-wal
data/*.db-shm

# Generated dashboard HTML (regenerated by Dashboard Agent)
dashboard/*.html

# Log files (large, rotated separately)
logs/

# OS
.DS_Store
Thumbs.db

# Node / Python if ever used
node_modules/
__pycache__/
*.pyc
.venv/

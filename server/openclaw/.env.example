# OpenClaw environment — copy to .env and fill in values
# .env is gitignored; never commit secrets

# Image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway token — generated during onboarding, treat like a password
OPENCLAW_GATEWAY_TOKEN=

# Data directories on the VPS host
OPENCLAW_CONFIG_DIR=/home/alex/apps/openclaw/config
OPENCLAW_WORKSPACE_DIR=/home/alex/apps/openclaw/workspace

# Bind to Tailscale IP only — keeps the dashboard off the public internet
# Replace with output of: tailscale ip -4
OPENCLAW_GATEWAY_PORT=100.67.100.125:18789
OPENCLAW_BRIDGE_PORT=100.67.100.125:18790

# Bind mode: lan = listen on all container interfaces (Docker handles host binding above)
OPENCLAW_GATEWAY_BIND=lan

# Timezone
OPENCLAW_TZ=Europe/Amsterdam

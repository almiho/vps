# Wrapper service
WRAPPER_PORT=8091
WRAPPER_API_TOKEN=replace-with-long-random-token

# Downstream MCP endpoint (Google MCP server)
DOWNSTREAM_MCP_URL=http://google-mcp-server:8090/mcp

# Runtime limits
REQUEST_TIMEOUT_MS=15000
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_DAY=5000
MAX_TOOL_CALLS_PER_REQUEST=1

# Paths
POLICY_FILE_PATH=./policy/allowlist.json
AUDIT_LOG_PATH=./data/audit.log
